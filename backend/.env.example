# Vorlage – kopieren und Werte anpassen: cp .env.example .env

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL-Verbindung
DATABASE_URL=postgresql://lego_user:seu_password@localhost:5432/lego_explorer

# CORS – URL des Frontends
FRONTEND_URL=http://localhost:5173

# Session
COOKIE_NAME=lego_session
SESSION_DAYS=7
