# PostgreSQL connection string
DATABASE_URL=postgresql://lego_user:seu_password@localhost:5432/lego_explorer

# Backend
PORT=3000
NODE_ENV=development

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Sessão
COOKIE_NAME=lego_session
SESSION_DAYS=7

# Credenciais do banco (usadas pelo Docker Compose)
POSTGRES_USER=lego_user
POSTGRES_PASSWORD=seu_password
POSTGRES_DB=lego_explorer
